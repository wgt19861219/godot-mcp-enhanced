{
  "name": "godot-mcp-enhanced",
  "version": "0.15.1",
  "description": "Enhanced MCP server for Godot game engine - closed-loop AI development with dynamic GDScript execution, scene tree query, node inspection, and more",
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "game-dev",
    "closed-loop"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "godot-mcp-enhanced": "./build/index.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "build/scripts/*.gd",
    "addons",
    "scripts"
  ],
  "scripts": {
    "install-plugin": "node scripts/install-plugin.js",
    "generate-docs": "node scripts/generate-doc-db.js",
    "lint": "eslint src/",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const src=p.join(__dirname,'src','scripts');const dst=p.join(__dirname,'build','scripts');fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.gd')).forEach(f=>{fs.copyFileSync(p.join(src,f),p.join(dst,f));console.log('Copied',f)})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/integration",
    "test:all": "vitest run",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.24",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.8.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
